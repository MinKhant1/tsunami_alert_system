# Vite only exposes variables that start with VITE_ (required for the client bundle).

# Backend API (browser must reach this host:port)
VITE_API_BASE_URL=http://localhost:8000

# Mapbox (optional) — public token from https://account.mapbox.com/ (free tier is fine).
# If you leave this empty, the app uses free MapLibre + demo/Carto tiles (no key).
# After changing: restart `npm run dev`. For Docker: rebuild the frontend image.
VITE_MAPBOX_TOKEN=

# Firebase (optional) — only for FCM in the browser
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_VAPID_KEY=
