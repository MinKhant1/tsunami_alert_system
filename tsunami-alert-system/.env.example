# Copy to `.env` in this folder (keep all environment files inside tsunami-alert-system/ only):
#   cp .env.example .env
# Frontend (Vite):  cp frontend/.env.example frontend/.env
#
# Docker Compose reads this file from this directory. Run: docker compose up --build

# ---------------------------------------------------------------------------
# Database (PostGIS) — use host "db" in Docker, "127.0.0.1" for local DB
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/tsunami_alert
# Local without Docker: postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/tsunami_alert

# ---------------------------------------------------------------------------
# Redis (Celery)
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
# Local: redis://127.0.0.1:6379/0

# ---------------------------------------------------------------------------
# Polling & zones
# ---------------------------------------------------------------------------
POLL_INTERVAL_SECONDS=60
SUBDUCTION_ZONE_BUFFER_DEG=2.0

# Optional USGS feed override
# USGS_EARTHQUAKE_FEED=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/6.0_hour.geojson

# ---------------------------------------------------------------------------
# FCM (server) — optional; leave empty to skip real device push from API
# ---------------------------------------------------------------------------
FIREBASE_SERVER_KEY=
FCM_URL=https://fcm.googleapis.com/fcm/send

# ---------------------------------------------------------------------------
# Twilio SMS (optional)
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---------------------------------------------------------------------------
# Frontend (Vite) — used for `npm run dev` in frontend/ AND for Docker build
# (docker compose passes these as build args; must be prefixed with VITE_)
# ---------------------------------------------------------------------------
# API base URL the browser calls (host machine: use localhost + backend port)
VITE_API_BASE_URL=http://localhost:8000
# Mapbox *public* access token (optional). Get one: https://account.mapbox.com/
# If empty, the UI uses free MapLibre demo tiles (no key). For Mapbox dark style, set this.
VITE_MAPBOX_TOKEN=
